# Supabase (REQUIRED for Part 1+)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Required for guest RSVP/check-in APIs, workspace bootstrap, and public guest pages.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Signed guest invitation links (recommended in production). Min 16 characters.
GUEST_LINK_SECRET=generate_a_long_random_string_here

# App
# Only needed if you are running on a custom domain (e.g. saathphere.com).
# On Vercel the URL is hardcoded to the production host. Locally the helper
# uses the live request origin, so this can stay unset for dev.
# All email/auth/invite links use https://7-phera.vercel.app (hardcoded in lib/utils/appUrl.ts).
# Auth emails open /auth/confirm on that host (not supabase.co) so localhost Site URL cannot redirect users.
# Do NOT set NEXT_PUBLIC_APP_URL to localhost on Vercel.
# Supabase Dashboard → Auth → URL: set Site URL to https://7-phera.vercel.app (still recommended).
# Optional override only for a custom domain:
# NEXT_PUBLIC_APP_URL=https://your-custom-domain.com
# Local dev only — use localhost in emails when testing Inbucket:
# USE_LOCAL_EMAIL_LINKS=true
# LOCAL_APP_ORIGIN=http://localhost:3000

# Resend (REQUIRED for signup confirmation, password reset, guest & workspace invites)
RESEND_API_KEY=your_resend_api_key
# The "From" line on outgoing emails. Format: "Name <email@your-verified-domain>".
# Defaults to "Saath Phere <invitations@resend.dev>" if unset (Resend sandbox).
RESEND_FROM=Saath Phere <hello@yourdomain.com>
# Optional. When guests hit "Reply", their reply goes here instead of bouncing
# off a noreply / non-existent mailbox. Use any inbox you actually read.
RESEND_REPLY_TO=you@gmail.com

# OpenAI (Part 12 - AI budget recommendations)
OPENAI_API_KEY=your_openai_api_key

# Razorpay (Part 12 - Payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id

# Superadmin (comma-separated emails)
# Users with these emails get is_superadmin=true set on next login.
# Once set in DB the flag persists, so this is just a seed list.
# Example: SUPERADMIN_EMAILS=bhavin@example.com,partner@example.com
SUPERADMIN_EMAILS=
